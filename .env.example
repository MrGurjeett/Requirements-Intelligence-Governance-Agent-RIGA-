# ================================================
# Enterprise Requirements Review Agent
# Environment Configuration
# ================================================

# Copilot Studio - Direct Line Credentials
# Get from: Copilot Studio → Settings → Channels → Direct Line
DIRECT_LINE_SECRET=your_direct_line_secret_here
BOT_ID=your_bot_id_here

# Microsoft Tenant
TENANT_ID=your_tenant_id_here

# Environment
# Options: dev | staging | prod
ENVIRONMENT=dev

# Agent Settings
MAX_RETRIES=1
TIMEOUT_MS=30000
LOG_LEVEL=info
